# ==================== DATABASE CONFIGURATION ====================
# Format: postgresql+asyncpg://user:password@host:port/database
# For development: postgresql+asyncpg://foodbank:foodbank@localhost:5432/foodbank
# For production: Update credentials and host to your production database
DATABASE_URL=postgresql+asyncpg://foodbank:foodbank@localhost:5432/foodbank


# ==================== SECURITY CONFIGURATION ====================

# REQUIRED: Secret key for JWT signing - must be a long, cryptographically secure random string
# Generate a secure key with one of these commands:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
#   openssl rand -hex 32
# CRITICAL: Never commit the actual key to version control. Use strong randomness.
# Minimum 32 characters recommended for production.
SECRET_KEY=<GENERATE_AND_PASTE_HERE>

# JWT Algorithm (HS256 recommended for symmetric keys, RS256 for asymmetric)
# Options: HS256, HS384, HS512, RS256, RS384, RS512
ALGORITHM=HS256

# Token Expiration Times
# Access tokens: Short-lived, used for API requests (15 min recommended)
# Refresh tokens: Long-lived, used to get new access tokens (7 days recommended)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7


# ==================== CORS CONFIGURATION ====================
# Frontend URLs allowed to access this API (comma-separated or JSON list)
# 
# Development examples:
#   CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# 
# Production examples (replace with actual frontend URLs):
#   CORS_ORIGINS=https://foodbank.example.com,https://www.foodbank.example.com
#   CORS_ORIGINS=["https://foodbank.example.com", "https://admin.foodbank.example.com"]
#
# SECURITY NOTE: In production, specify ONLY your frontend origins.
# Never use "*" (allow all origins) in production.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173


# ==================== APPLICATION CONFIGURATION ====================
# Application name displayed in API documentation and responses
APP_NAME=ABC Community Food Bank API

# Debug mode (disable in production)
# - True: Stack traces in error responses, development features enabled
# - False: Generic error messages, production mode
DEBUG=False
